#!/bin/bash
# ============================================================================
# voice-input - Continuous voice-to-text for tmux panes
# ============================================================================
# VAD loop: listens for speech, transcribes via voice-transcribe, shows a
# tmux popup for confirmation, then injects text into the target pane.
#
# Designed to run as a background process targeting a Claude Code pane.
#
# Usage:
#   voice-input <target-pane-id>           One-shot: record, confirm, inject
#   voice-input --listen <target-pane-id>  VAD loop: continuous listening
#   voice-input --check                    Check dependencies
#
# Dependencies: voice-transcribe, sox, whisper-cli, tmux

set -euo pipefail

# --- Configuration -----------------------------------------------------------

PIDFILE="${VOICE_INPUT_PIDFILE:-/tmp/voice-input-${USER}.pid}"

# --- Colors ------------------------------------------------------------------

if [ -t 1 ]; then
  BOLD='\033[1m' DIM='\033[2m'
  RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m' CYAN='\033[1;36m'
  NC='\033[0m'
else
  BOLD='' DIM='' RED='' GREEN='' YELLOW='' CYAN='' NC=''
fi

# --- Helpers -----------------------------------------------------------------

die() { echo -e "${RED}Error: $*${NC}" >&2; exit 1; }

check_deps() {
  local ok=true
  for cmd in voice-transcribe sox tmux; do
    if command -v "$cmd" &>/dev/null; then
      echo -e "  ${GREEN}✓${NC} $cmd"
    else
      echo -e "  ${RED}✗${NC} $cmd — not found"
      ok=false
    fi
  done
  # Delegate whisper + model check to voice-transcribe
  voice-transcribe --check
  $ok
}

# Confirm transcription in a tmux popup. Returns 0 if user confirms.
# Writes final text (possibly edited) to the given output file.
confirm_in_popup() {
  local text="$1"
  local target_pane="$2"
  local result_file="$3"

  # Build a small inline script for the popup
  local popup_script
  popup_script=$(cat <<'POPUP_EOF'
#!/bin/bash
TEXT="$1"
TARGET="$2"
RESULT_FILE="$3"

BOLD='\033[1m' DIM='\033[2m'
GREEN='\033[0;32m' YELLOW='\033[1;33m' CYAN='\033[1;36m' NC='\033[0m'

echo ""
echo -e "  ${CYAN}${BOLD}Voice Input${NC}"
echo ""
echo -e "  ${GREEN}Transcribed:${NC}"
echo ""
echo -e "  ${BOLD}${TEXT}${NC}"
echo ""
echo -e "  ${DIM}[Enter] Send  [e] Edit  [Esc/q] Cancel${NC}"
echo ""

read -rsn1 key
case "$key" in
  ""|$'\n')
    echo "$TEXT" > "$RESULT_FILE"
    ;;
  e|E)
    echo -ne "  Edit: "
    read -r -e -i "$TEXT" edited
    if [ -n "$edited" ]; then
      echo "$edited" > "$RESULT_FILE"
    fi
    ;;
esac
POPUP_EOF
  )

  local tmpscript
  tmpscript=$(mktemp /tmp/voice-popup-XXXXXX.sh)
  echo "$popup_script" > "$tmpscript"
  chmod +x "$tmpscript"

  # Run the popup, wait for it to finish
  tmux display-popup -E -w 70% -h 40% -T " Voice Input " \
    "$tmpscript" "$text" "$target_pane" "$result_file"

  rm -f "$tmpscript"

  # Check if user confirmed (result file has content)
  [ -s "$result_file" ]
}

# --- One-Shot Mode -----------------------------------------------------------

oneshot() {
  local target_pane="$1"

  local tmpfile result_file
  tmpfile=$(mktemp /tmp/voice-XXXXXX.wav)
  result_file=$(mktemp /tmp/voice-result-XXXXXX.txt)
  trap "rm -f '$tmpfile' '$result_file'" EXIT

  # Record and transcribe via voice-transcribe
  local text
  text=$(voice-transcribe) || return 1

  if [ -z "$text" ]; then
    return 1
  fi

  # Confirm via popup
  if confirm_in_popup "$text" "$target_pane" "$result_file"; then
    local final_text
    final_text=$(cat "$result_file")
    tmux send-keys -t "$target_pane" -l "$final_text"
  fi
}

# --- VAD Listen Loop ---------------------------------------------------------

listen_loop() {
  local target_pane="$1"

  # Write PID file so dev voice stop can find us
  echo $$ > "$PIDFILE"
  trap "rm -f '$PIDFILE'" EXIT INT TERM

  echo -e "${CYAN}${BOLD}Voice input active${NC} → pane $target_pane"
  echo -e "${DIM}Listening for speech... (Ctrl+C to stop)${NC}"
  echo ""

  while true; do
    local result_file
    result_file=$(mktemp /tmp/voice-result-XXXXXX.txt)

    # voice-transcribe --vad blocks until speech is detected and finished
    local text
    text=$(voice-transcribe --vad 2>/dev/null) || { rm -f "$result_file"; continue; }

    if [ -z "$text" ]; then
      rm -f "$result_file"
      continue
    fi

    echo -e "  ${GREEN}Heard:${NC} $text"

    # Confirm via popup
    if confirm_in_popup "$text" "$target_pane" "$result_file"; then
      local final_text
      final_text=$(cat "$result_file")
      tmux send-keys -t "$target_pane" -l "$final_text"
      echo -e "  ${GREEN}Sent.${NC}"
    else
      echo -e "  ${YELLOW}Cancelled.${NC}"
    fi

    rm -f "$result_file"
  done
}

# --- Entry Point -------------------------------------------------------------

case "${1:-}" in
  --check)
    check_deps
    ;;
  --listen)
    target="${2:-}"
    [ -n "$target" ] || die "Usage: voice-input --listen <target-pane-id>"
    listen_loop "$target"
    ;;
  --stop)
    if [ -f "$PIDFILE" ]; then
      pid=$(cat "$PIDFILE")
      if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        echo -e "${GREEN}Voice input stopped${NC} (PID $pid)"
      else
        echo -e "${YELLOW}Process $pid not running${NC}"
        rm -f "$PIDFILE"
      fi
    else
      echo -e "${YELLOW}No voice input running${NC}"
    fi
    ;;
  --status)
    if [ -f "$PIDFILE" ]; then
      pid=$(cat "$PIDFILE")
      if kill -0 "$pid" 2>/dev/null; then
        echo -e "${GREEN}Voice input running${NC} (PID $pid)"
        exit 0
      else
        echo -e "${YELLOW}Stale PID file${NC} (process $pid not running)"
        rm -f "$PIDFILE"
        exit 1
      fi
    else
      echo -e "${DIM}Voice input not running${NC}"
      exit 1
    fi
    ;;
  -h|--help)
    echo "Usage: voice-input [MODE] <target-pane-id>"
    echo ""
    echo "Modes:"
    echo "  <pane-id>              One-shot: record, confirm, inject"
    echo "  --listen <pane-id>     Continuous VAD loop targeting pane"
    echo "  --stop                 Stop the running listen loop"
    echo "  --status               Check if listen loop is running"
    echo "  --check                Check dependencies"
    echo "  -h, --help             Show this help"
    exit 0
    ;;
  "")
    die "Usage: voice-input <target-pane-id>\n       voice-input --listen <target-pane-id>\n       voice-input --help"
    ;;
  *)
    # Default: one-shot mode
    command -v voice-transcribe &>/dev/null || die "voice-transcribe not found in PATH"
    oneshot "$1"
    ;;
esac
