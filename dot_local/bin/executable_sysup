#!/bin/bash
# ============================================================================
# sysup - Cross-platform system update utility
# ============================================================================
# Single entry point for checking, upgrading, and diagnosing system packages
# across macOS, Linux, and WSL environments.
#
# Usage: sysup [command]
#   sysup              Show what's outdated (same as sysup status)
#   sysup status       Read-only: show what's outdated
#   sysup upgrade      Apply all updates
#   sysup repair       Fix broken packages and resolve dependency issues
#   sysup doctor       Check which tools are installed + versions
#   sysup help         Show usage text

set -euo pipefail

# --- Colors (guarded for pipe safety) ----------------------------------------

if [ -t 1 ]; then
  BOLD='\033[1m'
  DIM='\033[2m'
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  CYAN='\033[1;36m'
  NC='\033[0m'
else
  BOLD='' DIM='' RED='' GREEN='' YELLOW='' BLUE='' CYAN='' NC=''
fi

# --- Helpers ------------------------------------------------------------------

die()     { echo -e "${RED}Error: $*${NC}" >&2; exit 1; }
info()    { echo -e "${CYAN}$*${NC}"; }
warn()    { echo -e "${YELLOW}$*${NC}"; }
success() { echo -e "${GREEN}$*${NC}"; }
header()  { echo -e "\n${BOLD}${BLUE}── $* ──${NC}"; }

has() { command -v "$1" &>/dev/null; }

# --- Platform Detection -------------------------------------------------------

IS_WSL=false
IS_MACOS=false
IS_LINUX=false

if [[ "$OSTYPE" == "darwin"* ]]; then
  IS_MACOS=true
elif [ -f /proc/version ] && grep -qi "microsoft\|wsl" /proc/version; then
  IS_WSL=true
else
  IS_LINUX=true
fi

# --- Summary Tracking ---------------------------------------------------------

SUMMARY_ITEMS=()
FAILED_ITEMS=()

summary_ok()   { SUMMARY_ITEMS+=("${GREEN}✓${NC} $1"); }
summary_skip() { SUMMARY_ITEMS+=("${DIM}– $1 (skipped)${NC}"); }
summary_fail() { SUMMARY_ITEMS+=("${RED}✗ $1${NC}"); FAILED_ITEMS+=("$1"); }

print_summary() {
  header "Summary"
  for item in "${SUMMARY_ITEMS[@]}"; do
    echo -e "  $item"
  done
  if [ ${#FAILED_ITEMS[@]} -gt 0 ]; then
    echo ""
    warn "  ${#FAILED_ITEMS[@]} module(s) had errors"
  else
    echo ""
    success "  All modules completed successfully"
  fi
}

# === Package Manager Modules ==================================================
#
# Each module provides <name>_status and <name>_upgrade functions.
# Functions are gated by `has <command>` at the call site.

# --- 1. brew ------------------------------------------------------------------

brew_status() {
  header "Homebrew"
  if ! has brew; then summary_skip "brew"; return; fi
  info "Updating package index..."
  if brew update --quiet 2>/dev/null; then
    local outdated
    outdated=$(brew outdated --verbose 2>/dev/null)
    if [ -n "$outdated" ]; then
      echo "$outdated"
    else
      success "All formulae up to date"
    fi
    summary_ok "brew"
  else
    warn "brew update failed"
    summary_fail "brew"
  fi
}

brew_upgrade() {
  header "Homebrew"
  if ! has brew; then summary_skip "brew"; return; fi
  if brew update && brew upgrade && brew cleanup --prune=30; then
    if [ "$IS_MACOS" = true ]; then
      info "Upgrading casks..."
      brew upgrade --cask 2>/dev/null || true
    fi
    summary_ok "brew"
  else
    summary_fail "brew"
  fi
}

brew_repair() {
  header "Homebrew"
  if ! has brew; then summary_skip "brew"; return; fi
  info "Running diagnostics..."
  brew doctor 2>&1 | head -20 || true
  info "Cleaning up..."
  brew cleanup --prune=0
  info "Removing orphaned dependencies..."
  brew autoremove
  summary_ok "brew"
}

# --- 2. apt -------------------------------------------------------------------

apt_status() {
  header "APT"
  if ! has apt-get; then summary_skip "apt"; return; fi
  info "Updating package index..."
  if sudo apt-get update -qq 2>/dev/null; then
    local upgradable
    upgradable=$(apt list --upgradable 2>/dev/null | grep -v "^Listing")
    if [ -n "$upgradable" ]; then
      echo "$upgradable"
    else
      success "All packages up to date"
    fi
    summary_ok "apt"
  else
    warn "apt-get update failed"
    summary_fail "apt"
  fi
}

apt_upgrade() {
  header "APT"
  if ! has apt-get; then summary_skip "apt"; return; fi
  # Use dist-upgrade (full-upgrade) to handle dependency changes,
  # new packages, and removals — required for kernels, drivers, and
  # distros like Pop!_OS that restructure packages across updates.
  if sudo apt-get update -qq && sudo apt-get dist-upgrade -y && sudo apt-get autoremove -y && sudo apt-get autoclean; then
    summary_ok "apt"
  else
    summary_fail "apt"
  fi
}

apt_repair() {
  header "APT"
  if ! has apt-get; then summary_skip "apt"; return; fi
  info "Completing interrupted installs..."
  sudo dpkg --configure -a
  info "Resolving broken dependencies..."
  sudo apt-get --fix-broken install -y
  info "Cleaning package cache..."
  sudo apt-get clean
  info "Removing orphaned packages..."
  sudo apt-get autoremove -y
  summary_ok "apt"
}

# --- 3. fnm (Node.js) --------------------------------------------------------

fnm_status() {
  header "fnm (Node.js)"
  if ! has fnm; then summary_skip "fnm"; return; fi
  # Bootstrap fnm env in bash (shell integration isn't loaded)
  eval "$(fnm env --use-on-cd 2>/dev/null)" 2>/dev/null || true
  local current latest
  current=$(fnm current 2>/dev/null || echo "none")
  latest=$(fnm list-remote --lts 2>/dev/null | tail -1 || echo "unknown")
  echo "  Current: $current"
  echo "  Latest LTS: $latest"
  if [ "$current" = "$latest" ]; then
    success "Up to date"
  else
    warn "Update available: $current → $latest"
  fi
  summary_ok "fnm"
}

fnm_upgrade() {
  header "fnm (Node.js)"
  if ! has fnm; then summary_skip "fnm"; return; fi
  eval "$(fnm env --use-on-cd 2>/dev/null)" 2>/dev/null || true
  if fnm install --lts && fnm use lts-latest && fnm default lts-latest; then
    success "Node.js LTS installed and set as default"
    summary_ok "fnm"
  else
    summary_fail "fnm"
  fi
}

# --- 4. uv -------------------------------------------------------------------

uv_status() {
  header "uv"
  if ! has uv; then summary_skip "uv"; return; fi
  echo "  Version: $(uv --version 2>/dev/null)"
  local tools
  tools=$(uv tool list 2>/dev/null)
  if [ -n "$tools" ]; then
    echo "  Installed tools:"
    while IFS= read -r line; do echo "    $line"; done <<< "$tools"
  else
    echo "  No tools installed"
  fi
  summary_ok "uv"
}

uv_upgrade() {
  header "uv"
  if ! has uv; then summary_skip "uv"; return; fi
  # uv self update fails when installed via brew — catch and warn
  if uv self update 2>/dev/null; then
    success "uv binary updated"
  else
    warn "uv self update skipped (may be managed by brew)"
  fi
  if uv tool upgrade --all 2>/dev/null; then
    success "uv tools upgraded"
    summary_ok "uv"
  else
    summary_fail "uv"
  fi
}

# --- 5. pipx -----------------------------------------------------------------

pipx_status() {
  header "pipx"
  if ! has pipx; then summary_skip "pipx"; return; fi
  local packages
  packages=$(pipx list --short 2>/dev/null)
  if [ -n "$packages" ]; then
    while IFS= read -r line; do echo "  $line"; done <<< "$packages"
  else
    echo "  No packages installed"
  fi
  summary_ok "pipx"
}

pipx_upgrade() {
  header "pipx"
  if ! has pipx; then summary_skip "pipx"; return; fi
  if pipx upgrade-all 2>/dev/null; then
    summary_ok "pipx"
  else
    summary_fail "pipx"
  fi
}

# --- 6. tpm (tmux plugins) ---------------------------------------------------

tpm_status() {
  header "TPM (tmux plugins)"
  local tpm_updater="$HOME/.tmux/plugins/tpm/bin/update_plugins"
  if [ ! -x "$tpm_updater" ]; then summary_skip "tpm"; return; fi
  success "TPM is installed"
  echo "  Use ${BOLD}prefix + I${NC} inside tmux to update plugins interactively"
  summary_ok "tpm"
}

tpm_upgrade() {
  header "TPM (tmux plugins)"
  local tpm_updater="$HOME/.tmux/plugins/tpm/bin/update_plugins"
  if [ ! -x "$tpm_updater" ]; then summary_skip "tpm"; return; fi
  if "$tpm_updater" all; then
    summary_ok "tpm"
  else
    summary_fail "tpm"
  fi
}

# --- 7. vscode ----------------------------------------------------------------

vscode_status() {
  header "VS Code Extensions"
  if ! has code; then summary_skip "vscode"; return; fi
  local extensions
  extensions=$(code --list-extensions 2>/dev/null)
  local count
  count=$(echo "$extensions" | grep -c . || true)
  echo "  $count extension(s) installed"
  echo "  Auto-update is typically enabled in VS Code settings"
  summary_ok "vscode"
}

vscode_upgrade() {
  header "VS Code Extensions"
  if ! has code; then summary_skip "vscode"; return; fi
  local extensions
  extensions=$(code --list-extensions 2>/dev/null)
  if [ -z "$extensions" ]; then
    echo "  No extensions installed"
    summary_ok "vscode"
    return
  fi
  local total current=0
  total=$(echo "$extensions" | grep -c . || true)
  while IFS= read -r ext; do
    current=$((current + 1))
    echo -e "  [${current}/${total}] ${ext}"
    code --install-extension "$ext" --force 2>/dev/null || warn "  Failed to update $ext"
  done <<< "$extensions"
  summary_ok "vscode"
}

# --- 8. chezmoi ---------------------------------------------------------------

chezmoi_status() {
  header "chezmoi"
  if ! has chezmoi; then summary_skip "chezmoi"; return; fi
  local status
  status=$(chezmoi status 2>/dev/null)
  if [ -n "$status" ]; then
    echo "$status"
    warn "Pending changes detected"
  else
    success "No pending changes"
  fi
  summary_ok "chezmoi"
}

chezmoi_upgrade() {
  header "chezmoi"
  if ! has chezmoi; then summary_skip "chezmoi"; return; fi
  if chezmoi update --force; then
    summary_ok "chezmoi"
  else
    summary_fail "chezmoi"
  fi
}

# === Subcommands ==============================================================

# --- status (default) ---------------------------------------------------------

cmd_status() {
  info "Checking system status..."
  brew_status
  apt_status
  fnm_status
  uv_status
  pipx_status
  tpm_status
  vscode_status
  chezmoi_status
  print_summary
}

# --- upgrade ------------------------------------------------------------------

cmd_upgrade() {
  info "Upgrading system packages..."
  brew_upgrade
  apt_upgrade
  fnm_upgrade
  uv_upgrade
  pipx_upgrade
  tpm_upgrade
  vscode_upgrade
  chezmoi_upgrade
  print_summary
}

# --- repair -------------------------------------------------------------------

cmd_repair() {
  warn "This will attempt to fix broken packages and resolve dependency issues."
  echo ""

  # Confirmation prompt (skip with --yes or -y)
  if [ "${SYSUP_YES:-}" != "1" ]; then
    echo -ne "  Continue? [y/N] "
    read -r answer
    case "$answer" in
      [yY]|[yY][eE][sS]) ;;
      *) info "Aborted."; exit 0 ;;
    esac
  fi

  echo ""
  info "Repairing system packages..."
  brew_repair
  apt_repair
  print_summary
}

# --- doctor -------------------------------------------------------------------

cmd_doctor() {
  header "System Information"
  echo "  Platform: $(uname -s) $(uname -m)"
  echo "  Kernel:   $(uname -r)"
  if [ "$IS_MACOS" = true ]; then
    echo "  OS:       macOS $(sw_vers -productVersion 2>/dev/null || echo 'unknown')"
  elif [ "$IS_WSL" = true ]; then
    echo "  OS:       WSL ($(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 || echo 'unknown'))"
  elif [ "$IS_LINUX" = true ]; then
    echo "  OS:       $(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 || echo 'Linux')"
  fi
  echo "  Shell:    $SHELL"
  echo "  User:     $(whoami)"

  header "Package Managers"
  local tools_pm=(brew apt-get chezmoi fnm node npm uv pipx)
  for tool in "${tools_pm[@]}"; do
    check_tool "$tool"
  done

  header "Development Tools"
  local tools_dev=(git zsh tmux fzf docker python3 poetry just gh curl sysbak rsnapshot)
  for tool in "${tools_dev[@]}"; do
    check_tool "$tool"
  done

  header "Modern CLI Replacements"
  local tools_cli=(eza bat fd rg delta btop zoxide jq sensors sar)
  for tool in "${tools_cli[@]}"; do
    check_tool "$tool"
  done

  header "Key Paths"
  check_path "$HOME/.tmux/plugins/tpm" "TPM"
  check_path "$HOME/.oh-my-zsh" "oh-my-zsh"
  check_path "$HOME/.config/dev/config" "dev config"
  check_path "$HOME/.config/sysbak/config" "sysbak config"
  check_path "$HOME/Projects" "Projects directory"

  # Linux-specific daemon health
  if [ "$IS_LINUX" = true ] && has pop-upgrade; then
    header "Linux Daemon Health"
    local pu_pid pu_cpu
    pu_pid=$(pgrep -x pop-upgrade 2>/dev/null | head -1)
    if [ -n "$pu_pid" ]; then
      pu_cpu=$(ps -p "$pu_pid" -o %cpu= 2>/dev/null | tr -d ' ')
      if awk "BEGIN {exit !($pu_cpu > 5)}"; then
        echo -e "  ${YELLOW}⚠${NC}  pop-upgrade  ${YELLOW}${pu_cpu}% CPU (stuck? sudo systemctl restart pop-upgrade)${NC}"
      else
        echo -e "  ${GREEN}✓${NC}  pop-upgrade  ${GREEN}idle (${pu_cpu}% CPU)${NC}"
      fi
    else
      echo -e "  ${DIM}-${NC}  pop-upgrade  ${DIM}not running${NC}"
    fi
  fi
}

check_tool() {
  local tool="$1"
  if has "$tool"; then
    local version
    version=$(get_version "$tool" 2>/dev/null) || true
    if [ -n "$version" ]; then
      printf "  ${GREEN}✓${NC} %-14s %s\n" "$tool" "$version"
    else
      printf "  ${YELLOW}⚠${NC} %-14s %s\n" "$tool" "installed (version unavailable)"
    fi
  else
    printf "  ${RED}✗${NC} %-14s %s\n" "$tool" "not installed"
  fi
}

get_version() {
  local tool="$1"
  case "$tool" in
    node)      node --version 2>/dev/null ;;
    npm)       npm --version 2>/dev/null ;;
    python3)   python3 --version 2>/dev/null | awk '{print $2}' ;;
    git)       git --version 2>/dev/null | awk '{print $3}' ;;
    zsh)       zsh --version 2>/dev/null | awk '{print $2}' ;;
    tmux)      tmux -V 2>/dev/null | awk '{print $2}' ;;
    brew)      brew --version 2>/dev/null | head -1 | awk '{print $2}' ;;
    chezmoi)   chezmoi --version 2>/dev/null | awk '{print $1}' ;;
    fnm)       fnm --version 2>/dev/null ;;
    uv)        uv --version 2>/dev/null | awk '{print $2}' ;;
    pipx)      pipx --version 2>/dev/null ;;
    docker)    docker --version 2>/dev/null | awk '{print $3}' | tr -d ',' ;;
    poetry)    poetry --version 2>/dev/null | awk '{print $3}' | tr -d ')' ;;
    gh)        gh --version 2>/dev/null | head -1 | awk '{print $3}' ;;
    just)      just --version 2>/dev/null | awk '{print $2}' ;;
    curl)      curl --version 2>/dev/null | head -1 | awk '{print $2}' ;;
    fzf)       fzf --version 2>/dev/null | awk '{print $1}' ;;
    eza)       eza --version 2>/dev/null | head -1 | awk '{print $1}' ;;
    bat)       bat --version 2>/dev/null | awk '{print $2}' ;;
    fd)        fd --version 2>/dev/null | awk '{print $2}' ;;
    rg)        rg --version 2>/dev/null | head -1 | awk '{print $2}' ;;
    delta)     delta --version 2>/dev/null | awk '{print $2}' ;;
    btop)      btop --version 2>/dev/null | awk '{print $2}' ;;
    zoxide)    zoxide --version 2>/dev/null | awk '{print $2}' ;;
    jq)        jq --version 2>/dev/null | tr -d 'jq-' ;;
    apt-get)   apt-get --version 2>/dev/null | head -1 | awk '{print $2}' ;;
    sysbak)    sysbak version 2>/dev/null ;;
    rsnapshot) rsnapshot --version 2>&1 | head -1 ;;
    sensors)   sensors -v 2>/dev/null | awk '{print $3}' ;;
    sar)       sar -V 2>/dev/null | awk '{print $3}' ;;
    *)         "$tool" --version 2>/dev/null | head -1 ;;
  esac
}

check_path() {
  local path="$1"
  local label="$2"
  if [ -e "$path" ]; then
    printf "  ${GREEN}✓${NC} %-20s %s\n" "$label" "$path"
  else
    printf "  ${RED}✗${NC} %-20s %s\n" "$label" "$path (missing)"
  fi
}

# --- help ---------------------------------------------------------------------

show_help() {
  cat << 'EOF'
sysup - Cross-platform system update utility

USAGE
  sysup              Show what's outdated (same as sysup status)
  sysup status       Read-only: show what's outdated
  sysup upgrade      Apply all updates (uses full-upgrade for apt)
  sysup repair       Fix broken packages and resolve dependency issues
  sysup doctor       Check which tools are installed + versions
  sysup version      Show sysup version
  sysup help         Show this help

PACKAGE MANAGERS (checked in order)
  brew               Homebrew formulae (and casks on macOS)
  apt                System packages (Linux/WSL only, requires sudo)
  fnm                Node.js LTS via fnm
  uv                 uv binary and uv-managed tools
  pipx               pipx-managed Python packages
  tpm                Tmux plugins via TPM
  vscode             VS Code extensions
  chezmoi            Dotfiles sync (runs last)

REPAIR (sysup repair)
  apt                dpkg --configure -a, apt --fix-broken install,
                     apt clean, apt autoremove
  brew               brew doctor, brew cleanup, brew autoremove

EXAMPLES
  sysup              # Quick check: what needs updating?
  sysup upgrade      # Update everything
  sysup repair       # Fix broken packages
  sysup doctor       # Verify tool installation
EOF
}

# --- version ------------------------------------------------------------------

show_version() {
  echo "sysup 1.1.0"
}

# === Main =====================================================================

main() {
  case "${1:-}" in
    ""| status)
      cmd_status
      ;;
    upgrade)
      cmd_upgrade
      ;;
    repair|fix)
      cmd_repair
      ;;
    doctor)
      cmd_doctor
      ;;
    version|--version|-v)
      show_version
      ;;
    help|--help|-h)
      show_help
      ;;
    *)
      die "Unknown command: $1 (try 'sysup help')"
      ;;
  esac
}

main "$@"
