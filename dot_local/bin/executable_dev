#!/usr/bin/env bash
# ============================================================================
# dev - Persistent tmux session manager for multi-device development
# ============================================================================
# Single entry point for creating, attaching, and managing tmux sessions
# with automatic project discovery across ~/Projects.
#
# Usage: dev [command] [args]
#   dev                     Interactive picker (fzf or fallback)
#   dev <project>           Create or attach to session for <project>
#   dev claude <project>    Force claude+shell layout
#   dev detach              Detach from current tmux session
#   dev kill <name>         Kill a session
#   dev kill-all            Kill all sessions (with confirmation)
#   dev help                Show full help

set -euo pipefail

# Require bash 4+ for associative arrays
if ((BASH_VERSINFO[0] < 4)); then
  echo "Error: dev requires bash 4+. Found: $BASH_VERSION" >&2
  echo "Install with: brew install bash" >&2
  exit 1
fi

# --- Configuration -----------------------------------------------------------

PROJECTS_DIR="$HOME/Projects"
CONFIG_FILE="$HOME/.config/dev/config"
MAX_DEPTH=3

# --- Colors (guarded for pipe safety) ----------------------------------------

if [ -t 1 ]; then
  BOLD='\033[1m'
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  CYAN='\033[1;36m'
  NC='\033[0m'
else
  BOLD='' RED='' GREEN='' YELLOW='' CYAN='' NC=''
fi

# --- Helpers ------------------------------------------------------------------

die() { echo -e "${RED}Error: $*${NC}" >&2; exit 1; }
info() { echo -e "${CYAN}$*${NC}"; }

# Read a config value. Returns the value or empty string.
config_get() {
  local key="$1"
  if [ -f "$CONFIG_FILE" ]; then
    sed -n "s/^${key}=//p" "$CONFIG_FILE" | tail -1
  fi
}

# Get the layout for a project: check config, then default_layout, then "default".
# Strips @host suffix and :path suffix if present.
get_layout() {
  local project="$1"
  local raw
  raw=$(config_get "$project")
  if [ -z "$raw" ]; then
    raw=$(config_get "default_layout")
  fi
  # Strip @host if present, then strip :path if present
  local without_host="${raw%%@*}"
  local layout="${without_host%%:*}"
  echo "${layout:-default}"
}

# Get the remote host for a project. Returns empty if local.
get_host() {
  local project="$1"
  local raw
  raw=$(config_get "$project")
  if [[ "$raw" == *@* ]]; then
    echo "${raw#*@}"
  fi
}

# Get the custom path for a project. Returns empty if no custom path.
get_path() {
  local project="$1"
  local raw
  raw=$(config_get "$project")
  [ -z "$raw" ] && return
  # Strip @host if present, then check for :path
  local without_host="${raw%%@*}"
  if [[ "$without_host" == *:* ]]; then
    local path_part="${without_host#*:}"
    echo "${path_part/#\~/$HOME}"
  fi
}

# Check if a project should be forwarded to a remote host.
# If so, exec ssh (does not return). Otherwise returns normally.
# Usage: maybe_forward_remote <project> [dev args...]
maybe_forward_remote() {
  local project="$1"
  shift
  local host
  host=$(get_host "$project")
  if [ -n "$host" ]; then
    local local_hostname
    local_hostname=$(hostname -s 2>/dev/null || hostname)
    if [ "$local_hostname" != "$host" ]; then
      exec ssh -t "$host" "dev $*"
    fi
  fi
}

# --- Project Discovery -------------------------------------------------------

# Discover projects under ~/Projects by finding .git directories.
# Outputs lines of: display_name<TAB>full_path
discover_projects() {
  [ -d "$PROJECTS_DIR" ] || return 0

  local -A name_count=()
  local -a entries=()

  # Find all git repos up to MAX_DEPTH levels deep
  while IFS= read -r gitdir; do
    local project_path="${gitdir%/.git}"
    local rel_path="${project_path#"$PROJECTS_DIR"/}"
    local name="${rel_path##*/}"
    entries+=("$rel_path")
    name_count[$name]=$(( ${name_count[$name]:-0} + 1 ))
  done < <(find "$PROJECTS_DIR" -maxdepth "$MAX_DEPTH" -name .git -type d 2>/dev/null | sort)

  # Output with collision handling
  for rel_path in "${entries[@]}"; do
    local name="${rel_path##*/}"
    local display_name
    if [ "${name_count[$name]}" -gt 1 ]; then
      display_name="$rel_path"
    else
      display_name="$name"
    fi
    echo -e "${display_name}\t${PROJECTS_DIR}/${rel_path}"
  done

  # Append custom-path entries from config
  if [ -f "$CONFIG_FILE" ]; then
    while IFS='=' read -r key value; do
      [[ "$key" =~ ^#.*$ || -z "$key" || "$key" == "default_layout" ]] && continue
      local without_host="${value%%@*}"
      if [[ "$without_host" == *:* ]]; then
        local custom_path="${without_host#*:}"
        custom_path="${custom_path/#\~/$HOME}"
        [ -d "$custom_path" ] && echo -e "${key}\t${custom_path}"
      fi
    done < "$CONFIG_FILE"
  fi
}

# Resolve a project name/pattern to a full path.
# Supports exact match, basename match, and fuzzy partial match.
resolve_project() {
  local query="$1"
  local match=""

  while IFS=$'\t' read -r display_name full_path; do
    # Exact match on display name
    if [ "$display_name" = "$query" ]; then
      echo "$full_path"
      return 0
    fi
    # Exact match on directory basename
    local basename="${full_path##*/}"
    if [ "$basename" = "$query" ]; then
      match="$full_path"
    fi
  done < <(discover_projects)

  if [ -n "$match" ]; then
    echo "$match"
    return 0
  fi

  # Fuzzy: partial substring match on display name
  while IFS=$'\t' read -r display_name full_path; do
    if [[ "$display_name" == *"$query"* ]]; then
      echo "$full_path"
      return 0
    fi
  done < <(discover_projects)

  return 1
}

# --- Session Management ------------------------------------------------------

# Create a new tmux session with the given layout.
create_session() {
  local session_name="$1"
  local project_path="$2"
  local layout="$3"

  case "$layout" in
    claude)
      # Create session with claude in the first pane
      tmux new-session -d -s "$session_name" -c "$project_path"
      # Split vertically: left pane gets claude, right pane is shell
      tmux split-window -h -t "$session_name" -c "$project_path"
      # Select left pane and run claude
      tmux select-pane -t "$session_name:1.1"
      tmux send-keys -t "$session_name:1.1" 'claude' Enter
      # Focus the right (shell) pane
      tmux select-pane -t "$session_name:1.2"
      ;;
    *)
      # Default: single shell pane
      tmux new-session -d -s "$session_name" -c "$project_path"
      ;;
  esac
}

# Attach or switch to a session.
attach_session() {
  local session_name="$1"
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$session_name"
  else
    tmux attach-session -t "$session_name"
  fi
}

# Open a project: create session if needed, then attach.
open_project() {
  local query="$1"
  local force_layout="${2:-}"

  # 1. Remote check FIRST (before local resolution).
  #    Uses the query name to look up config. If remote, SSH forward
  #    and never return. This works even if the project doesn't exist locally.
  if [ -n "$force_layout" ]; then
    maybe_forward_remote "$query" "$force_layout" "$query"
  else
    maybe_forward_remote "$query" "$query"
  fi

  # 2. Check if it's an existing local session
  if tmux has-session -t "=$query" 2>/dev/null; then
    attach_session "$query"
    return 0
  fi

  # 3. Resolve local project path (check custom path first, then discover)
  local project_path
  local custom_path
  custom_path=$(get_path "$query")
  if [ -n "$custom_path" ]; then
    [ -d "$custom_path" ] || die "Custom path for '$query' does not exist: $custom_path"
    project_path="$custom_path"
  elif ! project_path=$(resolve_project "$query"); then
    die "Project '$query' not found in $PROJECTS_DIR"
  fi

  # Use config key as session name for custom-path projects, otherwise basename
  local session_name
  if [ -n "$custom_path" ]; then
    session_name="$query"
  else
    session_name="${project_path##*/}"
  fi

  # 4. Also check resolved name for remote (in case query was fuzzy-matched)
  if [ "$session_name" != "$query" ]; then
    if [ -n "$force_layout" ]; then
      maybe_forward_remote "$session_name" "$force_layout" "$session_name"
    else
      maybe_forward_remote "$session_name" "$session_name"
    fi
  fi

  local layout="${force_layout:-$(get_layout "$session_name")}"

  # Session might exist under the resolved name
  if tmux has-session -t "=$session_name" 2>/dev/null; then
    attach_session "$session_name"
    return 0
  fi

  info "Creating session '${session_name}' (${layout} layout)..."
  create_session "$session_name" "$project_path" "$layout"
  attach_session "$session_name"
}

# --- Interactive Picker -------------------------------------------------------

# Get formatted session info for display.
format_sessions() {
  tmux list-sessions -F '#{session_name}|#{session_windows}|#{session_attached}|#{session_activity}' 2>/dev/null | while IFS='|' read -r name _windows attached activity; do
    local status_info=""
    if [ "$attached" -gt 0 ]; then
      status_info="(attached)"
    else
      # Calculate time since last activity
      local now
      now=$(date +%s)
      local diff=$(( now - activity ))
      if [ "$diff" -lt 60 ]; then
        status_info="${diff}s ago"
      elif [ "$diff" -lt 3600 ]; then
        status_info="$(( diff / 60 ))m ago"
      else
        status_info="$(( diff / 3600 ))h ago"
      fi
    fi

    # Try to detect layout
    local pane_count
    pane_count=$(tmux list-panes -t "$name" 2>/dev/null | wc -l)
    local layout_label="shell"
    if [ "$pane_count" -ge 2 ]; then
      layout_label="claude+shell"
    fi

    printf "  %-24s %-16s %s\n" "$name" "$layout_label" "$status_info"
  done
}

# Interactive picker using fzf.
picker_fzf() {
  local entries=()
  local session_names=()

  # Active sessions
  if tmux list-sessions &>/dev/null; then
    while IFS='|' read -r name _windows attached activity; do
      local status_info=""
      if [ "$attached" -gt 0 ]; then
        status_info="(attached)"
      else
        local now
        now=$(date +%s)
        local diff=$(( now - activity ))
        if [ "$diff" -lt 60 ]; then
          status_info="${diff}s ago"
        elif [ "$diff" -lt 3600 ]; then
          status_info="$(( diff / 60 ))m ago"
        else
          status_info="$(( diff / 3600 ))h ago"
        fi
      fi

      local pane_count
      pane_count=$(tmux list-panes -t "$name" 2>/dev/null | wc -l)
      local layout_label="shell"
      if [ "$pane_count" -ge 2 ]; then
        layout_label="claude+shell"
      fi

      entries+=("$(printf "[session]  %-22s %-14s %s" "$name" "$layout_label" "$status_info")")
      session_names+=("$name")
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}|#{session_attached}|#{session_activity}' 2>/dev/null)
  fi

  # Available local projects
  local -A seen_projects=()
  while IFS=$'\t' read -r display_name full_path; do
    # Skip projects that already have a session
    local basename="${full_path##*/}"
    local already_active=false
    for s in "${session_names[@]+"${session_names[@]}"}"; do
      if [ "$s" = "$basename" ]; then
        already_active=true
        break
      fi
    done
    if ! $already_active; then
      local host_annotation=""
      local host
      host=$(get_host "$basename")
      if [ -n "$host" ]; then
        host_annotation="  @${host}"
      fi
      entries+=("$(printf "[project]  %-22s %s%s" "$display_name" "$full_path" "$host_annotation")")
      seen_projects[$basename]=1
    fi
  done < <(discover_projects)

  # Add config-only remote projects (not found locally)
  local local_hostname
  local_hostname=$(hostname -s 2>/dev/null || hostname)
  if [ -f "$CONFIG_FILE" ]; then
    while IFS='=' read -r key value; do
      [[ "$key" =~ ^#.*$ || -z "$key" || "$key" == "default_layout" ]] && continue
      if [[ "$value" == *@* ]]; then
        local cfg_host="${value#*@}"
        if [ "$cfg_host" != "$local_hostname" ] && [ -z "${seen_projects[$key]+_}" ]; then
          local already_active=false
          for s in "${session_names[@]+"${session_names[@]}"}"; do
            if [ "$s" = "$key" ]; then
              already_active=true
              break
            fi
          done
          if ! $already_active; then
            entries+=("$(printf "[project]  %-22s @%s" "$key" "$cfg_host")")
          fi
        fi
      fi
    done < "$CONFIG_FILE"
  fi

  if [ ${#entries[@]} -eq 0 ]; then
    die "No sessions or projects found"
  fi

  local selection
  selection=$(printf '%s\n' "${entries[@]}" | fzf \
    --ansi \
    --header="  dev: select a session or project" \
    --prompt="  > " \
    --height=40% \
    --reverse \
    --no-sort) || return 1

  # Parse selection
  local type name
  type=$(echo "$selection" | awk '{print $1}')
  name=$(echo "$selection" | awk '{print $2}')

  if [ "$type" = "[session]" ]; then
    attach_session "$name"
  elif [ "$type" = "[project]" ]; then
    open_project "$name"
  fi
}

# Fallback picker without fzf: numbered list.
picker_fallback() {
  local entries=()
  local types=()
  local names=()
  local session_names=()
  local idx=1

  # Active sessions
  if tmux list-sessions &>/dev/null; then
    echo -e "\n${BOLD} ACTIVE SESSIONS${NC}"
    while IFS='|' read -r name _windows attached activity; do
      local status_info=""
      if [ "$attached" -gt 0 ]; then
        status_info="(attached)"
      else
        local now
        now=$(date +%s)
        local diff=$(( now - activity ))
        if [ "$diff" -lt 60 ]; then
          status_info="${diff}s ago"
        elif [ "$diff" -lt 3600 ]; then
          status_info="$(( diff / 60 ))m ago"
        else
          status_info="$(( diff / 3600 ))h ago"
        fi
      fi

      local pane_count
      pane_count=$(tmux list-panes -t "$name" 2>/dev/null | wc -l)
      local layout_label="shell"
      if [ "$pane_count" -ge 2 ]; then
        layout_label="claude+shell"
      fi

      printf "  ${GREEN}%2d)${NC} %-22s %-14s %s\n" "$idx" "$name" "$layout_label" "$status_info"
      types+=("session")
      names+=("$name")
      session_names+=("$name")
      idx=$((idx + 1))
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}|#{session_attached}|#{session_activity}' 2>/dev/null)
  fi

  # Available local projects
  local has_projects=false
  local -A seen_projects=()
  while IFS=$'\t' read -r display_name full_path; do
    local basename="${full_path##*/}"
    local already_active=false
    for s in "${session_names[@]+"${session_names[@]}"}"; do
      if [ "$s" = "$basename" ]; then
        already_active=true
        break
      fi
    done
    if ! $already_active; then
      if ! $has_projects; then
        echo -e "\n${BOLD} AVAILABLE PROJECTS${NC}"
        has_projects=true
      fi
      local host_annotation=""
      local host
      host=$(get_host "$basename")
      if [ -n "$host" ]; then
        host_annotation="  @${host}"
      fi
      printf "  ${GREEN}%2d)${NC} %-22s %s%s\n" "$idx" "$display_name" "$full_path" "$host_annotation"
      types+=("project")
      names+=("$display_name")
      seen_projects[$basename]=1
      idx=$((idx + 1))
    fi
  done < <(discover_projects)

  # Add config-only remote projects (not found locally)
  local local_hostname
  local_hostname=$(hostname -s 2>/dev/null || hostname)
  if [ -f "$CONFIG_FILE" ]; then
    while IFS='=' read -r key value; do
      [[ "$key" =~ ^#.*$ || -z "$key" || "$key" == "default_layout" ]] && continue
      if [[ "$value" == *@* ]]; then
        local cfg_host="${value#*@}"
        if [ "$cfg_host" != "$local_hostname" ] && [ -z "${seen_projects[$key]+_}" ]; then
          local already_active=false
          for s in "${session_names[@]+"${session_names[@]}"}"; do
            if [ "$s" = "$key" ]; then
              already_active=true
              break
            fi
          done
          if ! $already_active; then
            if ! $has_projects; then
              echo -e "\n${BOLD} AVAILABLE PROJECTS${NC}"
              has_projects=true
            fi
            printf "  ${GREEN}%2d)${NC} %-22s @%s\n" "$idx" "$key" "$cfg_host"
            types+=("project")
            names+=("$key")
            idx=$((idx + 1))
          fi
        fi
      fi
    done < "$CONFIG_FILE"
  fi

  if [ ${#names[@]} -eq 0 ]; then
    die "No sessions or projects found"
  fi

  echo ""
  read -rp "  Select [1-$((idx - 1))]: " choice

  if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -ge "$idx" ]; then
    die "Invalid selection"
  fi

  local selected_idx=$((choice - 1))
  local selected_type="${types[$selected_idx]}"
  local selected_name="${names[$selected_idx]}"

  if [ "$selected_type" = "session" ]; then
    attach_session "$selected_name"
  else
    open_project "$selected_name"
  fi
}

# Run the interactive picker.
picker() {
  if command -v fzf &>/dev/null; then
    picker_fzf
  else
    picker_fallback
  fi
}

# --- Help ---------------------------------------------------------------------

show_help() {
  cat << 'EOF'
dev - Persistent tmux session manager for multi-device development

USAGE
  dev                     Interactive picker (fzf or numbered fallback)
  dev <project>           Create or attach to session for <project>
  dev claude <project>    Force claude+shell layout (vertical split)
  dev detach              Detach from current tmux session
  dev kill <name>         Kill a session
  dev kill-all            Kill all sessions (with confirmation)
  dev help                Show this help

LAYOUTS
  default                 Single shell pane in the project directory
  claude                  Vertical split: claude (left) + shell (right)

PROJECT DISCOVERY
  Projects are auto-discovered from ~/Projects (up to 3 levels deep).
  A project is any directory containing a .git folder.
  If names collide, the category/project form is used.

CONFIGURATION
  Per-project layouts are configured in ~/.config/dev/config:

    default_layout=default
    atomicguard=claude@myserver
    manta-deploy=claude@myserver
    my-local-thing=default
    dotfiles=claude:~/.local/share/chezmoi

  Format: project=layout[:path][@host]
  - layout: default, claude
  - :path:  optional custom directory (expands ~); omit for ~/Projects projects
  - @host:  optional SSH hostname; omit for local projects

  Custom-path projects appear in the picker alongside ~/Projects entries
  and use the config key as the session name.

REMOTE PROJECTS
  If a project has @host in its config and the local hostname doesn't
  match, `dev` will SSH to that host and run `dev` there. This works
  for opening, killing, and the interactive picker. Projects that only
  exist on a remote host still appear in the picker.

INSIDE TMUX
  Running `dev <x>` inside tmux switches to that session (no nesting).

EXAMPLES
  dev                     # Pick from sessions/projects interactively
  dev atomicguard         # Open atomicguard with configured layout
  dev dotfiles            # Open dotfiles in custom path (chezmoi dir)
  dev claude myproject    # Open myproject with claude+shell split
  dev kill myproject      # Kill myproject session
EOF
}

# --- Main ---------------------------------------------------------------------

main() {
  # Check tmux is available
  command -v tmux &>/dev/null || die "tmux is not installed"

  case "${1:-}" in
    "")
      picker
      ;;
    help|--help|-h)
      show_help
      ;;
    detach)
      if [ -n "${TMUX:-}" ]; then
        tmux detach-client
      else
        die "Not inside a tmux session"
      fi
      ;;
    kill)
      local name="${2:-}"
      [ -n "$name" ] || die "Usage: dev kill <session-name>"
      maybe_forward_remote "$name" kill "$name"
      if tmux has-session -t "=$name" 2>/dev/null; then
        tmux kill-session -t "=$name"
        info "Session '$name' killed"
      else
        die "Session '$name' does not exist"
      fi
      ;;
    kill-all)
      local count
      count=$(tmux list-sessions 2>/dev/null | wc -l)
      if [ "$count" -eq 0 ]; then
        info "No sessions to kill"
        return 0
      fi
      echo -e "${YELLOW}This will kill $count session(s):${NC}"
      tmux list-sessions 2>/dev/null | while read -r line; do
        echo "  $line"
      done
      read -rp "Confirm? [y/N] " confirm
      if [[ "$confirm" =~ ^[yY]$ ]]; then
        tmux kill-server
        info "All sessions killed"
      else
        info "Cancelled"
      fi
      ;;
    claude)
      local project="${2:-}"
      [ -n "$project" ] || die "Usage: dev claude <project>"
      open_project "$project" "claude"
      ;;
    *)
      open_project "$1"
      ;;
  esac
}

main "$@"
